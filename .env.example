# === Django ===
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# === Ma'lumotlar bazasi ===
# Dev (standart): SQLite
DATABASE_URL=sqlite:///db.sqlite3
# Prod namuna: PostgreSQL
# DATABASE_URL=postgres://orderflow:parol@localhost:5432/orderflow

# === Til / vaqt mintaqasi ===
LANGUAGE_CODE=uz
TIME_ZONE=Asia/Tashkent

# === Sayt manzili (QR kodlar uchun) ===
SITE_URL=http://127.0.0.1:8000

# === Web Push (VAPID) ===
# vapid_private.pem va VAPID_PUBLIC_KEY python skripti orqali generatsiya qilinadi
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=mailto:admin@orderflow.uz

# === Xavfsizlik (production) ===
# DEBUG=False bo'lganda HTTPS/cookie himoyasi avtomatik yoqiladi.
# CSRF_TRUSTED_ORIGINS: vergul bilan, masalan: https://orderflow.uz
CSRF_TRUSTED_ORIGINS=

# === To'lov tizimlari (Payme / Click) ===
# Test rejimi (sandbox). Production'da False qiling.
PAYMENT_TEST_MODE=True

# --- Payme (Merchant API) ---
# Kabinet: https://merchant.payme.uz | Test stend: https://test.paycom.uz
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
# Test checkout: https://checkout.test.paycom.uz | Prod: https://checkout.paycom.uz
PAYME_CHECKOUT_URL=https://checkout.test.paycom.uz
# Kabinetda sozlangan hisob (account) maydoni nomi — odatda order_id
PAYME_ACCOUNT_FIELD=order_id

# --- Click (SHOP API) ---
# Kabinet: https://merchant.click.uz
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_USER_ID=
CLICK_PAY_URL=https://my.click.uz/services/pay
